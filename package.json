{
  "name": "@helloagentai/openclaw",
  "version": "0.1.2",
  "description": "OpenClaw HelloAgent channel plugin (relay-backed messaging)",
  "license": "MIT",
  "author": "HelloAgent",
  "homepage": "https://github.com/helloagentai/helloagent-openclaw#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/helloagentai/helloagent-openclaw.git"
  },
  "bugs": {
    "url": "https://github.com/helloagentai/helloagent-openclaw/issues"
  },
  "keywords": [
    "helloagent",
    "openclaw",
    "channel",
    "plugin",
    "relay"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "index.cjs",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test:smoke": "tsx tests/smoke.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "openclaw": ">=2026.4.24"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "dependencies": {
    "@helloagentai/sdk": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "openclaw": "^2026.4.24",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "helloagent",
      "label": "HelloAgent",
      "selectionLabel": "HelloAgent (relay)",
      "docsPath": "/channels/helloagent",
      "docsLabel": "helloagent",
      "blurb": "Relay-backed messaging for HelloAgent personal agents.",
      "persistedAuthState": {
        "specifier": "./dist/src/auth/presence.js",
        "exportName": "hasAnyHelloAgentAuth"
      }
    }
  }
}
